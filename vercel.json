{
  "rewrites": [
    { "source": "/samsung",        "destination": "/milo-samsung-proposal/index.html" },
    { "source": "/samsung/(.*)",   "destination": "/milo-samsung-proposal/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" }
      ]
    }
  ]
}
