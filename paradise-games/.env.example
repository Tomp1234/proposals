# Anthropic — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Webflow — get from Webflow dashboard > Account Settings > API
WEBFLOW_API_TOKEN=...
WEBFLOW_SITE_ID=...          # Settings > General inside your Webflow site
WEBFLOW_COLLECTION_ID=...    # CMS > Proposals collection > Settings

# Milo logo (publicly accessible URL, used in every proposal hero)
MILO_LOGO_URL=https://framerusercontent.com/images/6CxE8i0ipM3Kf86VeCuaSMk9dU.png

# Upstash Redis — add the Redis integration from vercel.com/marketplace, it auto-populates these
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...
